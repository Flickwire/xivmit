{
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "endTime": {
      "type": "number"
    },
    "timeline": {
      "type": "object",
      "patternProperties": {
        "^\\d+$": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "abilityName": {
                "type": "string"
              }
            },
            "required": ["type", "abilityName"]
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "descriptions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "required": ["id", "name", "endTime", "timeline", "descriptions"],
  "additionalProperties": false
}
